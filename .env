# LLM（new api 中转）
llm_api_key=xxx
llm_base_url=xxx
llm_model=qwen3.5-plus

# Embedding
embedding_model=Qwen/Qwen3-Embedding-8B

# Nacos
nacos_server=xxx:8848
nacos_namespace=business-server

# Skills 目录
skills_dir=./skills

# PostgreSQL
postgres_dsn=postgresql+asyncpg://admin:admin123@xxx:5432/postgres

# 语义缓存相似度阈值
cache_similarity_threshold=0.92
